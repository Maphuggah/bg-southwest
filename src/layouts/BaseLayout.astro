---
import '../styles/global.css';

const { title, description } = Astro.props;
const pathname = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <slot name="head" />
</head>
<body>

  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="brand-logo">
        <img src="/img/logo.png" alt="B&G Southwest" style="height: 72px; width: auto; object-fit: contain;">
      </a>
      <div class="nav-links">
        <a href="/" style={isActive('/') ? 'color: var(--brand-amber);' : ''}>Home</a>
        <a href="/services" style={isActive('/services') ? 'color: var(--brand-amber);' : ''}>Services</a>
        <a href="/about" style={isActive('/about') ? 'color: var(--brand-amber);' : ''}>About Us</a>
        <a href="/areas" style={isActive('/areas') ? 'color: var(--brand-amber);' : ''}>Areas Served</a>
        <a href="/contact" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.9rem;">Get a Quote</a>
      </div>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div>
          <a href="/" class="brand-logo" style="margin-bottom: 1rem; display: inline-block;">
            <img src="/img/logo.png" alt="B&G Southwest" style="height: 72px; width: auto; object-fit: contain;">
          </a>
          <p style="color: #94a3b8; font-size: 0.95rem;">Delivering absolute excellence in commercial surface care across San Diego. The gold standard applied to facility maintenance.</p>
        </div>
        <div>
          <h4>Services</h4>
          <ul class="footer-links">
            <li><a href="/services#hard-floors">Hard Floor Maintenance</a></li>
            <li><a href="/services#carpet-care">Carpet Care</a></li>
            <li><a href="/services#concrete">Concrete Polishing</a></li>
            <li><a href="/services">Specialty Surfaces</a></li>
          </ul>
        </div>
        <div>
          <h4>Company</h4>
          <ul class="footer-links">
            <li><a href="/about">Our Story</a></li>
            <li><a href="/areas">Areas Served</a></li>
            <li><a href="/contact">Careers</a></li>
          </ul>
        </div>
        <div>
          <h4>Contact</h4>
          <ul class="footer-links">
            <li style="color: #cbd5e1;">(619) 738-6819</li>
            <li style="color: #cbd5e1;">clean@bandgsouthwest.com</li>
            <li style="color: #cbd5e1;">San Diego, CA</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; 2026 B & G Southwest. All rights reserved.
      </div>
    </div>
  </footer>

</body>
</html>
