---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Us | Request a Quote | B & G Southwest"
  description="Contact B & G Southwest for a commercial surface care and facility maintenance assessment in San Diego."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://bgsouthwest.com/#organization",
          "name": "B & G Southwest",
          "description": "Premium commercial surface care, facility maintenance, and hard floor restoration services in San Diego County.",
          "url": "https://bgsouthwest.com",
          "telephone": "+1-619-555-0199",
          "areaServed": "San Diego County",
          "image": "https://bgsouthwest.com/img/hero.png",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "San Diego",
            "addressRegion": "CA",
            "addressCountry": "US"
          },
          "priceRange": "$$",
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "reviewCount": "110"
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://bgsouthwest.com/#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://bgsouthwest.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Contact Us",
              "item": "https://bgsouthwest.com/contact"
            }
          ]
        },
        {
          "@type": "ContactPage",
          "@id": "https://bgsouthwest.com/contact#webpage",
          "url": "https://bgsouthwest.com/contact",
          "name": "Contact Us | Request a Quote | B & G Southwest",
          "isPartOf": {"@id": "https://bgsouthwest.com/#website"},
          "breadcrumb": {"@id": "https://bgsouthwest.com/#breadcrumb"},
          "about": {"@id": "https://bgsouthwest.com/#organization"},
          "keywords": "contact B & G Southwest, request quote, San Diego commercial cleaning contact"
        }
      ]
    }
    </script>
  </Fragment>

  <main style="padding-top: 100px;">
    <section class="section-padding container">
      <div class="grid grid-2" style="align-items: start; gap: 4rem;">

        <!-- Contact Info -->
        <div>
          <h1 style="margin-bottom: 1rem;">Deploy Our Team.</h1>
          <p>Every facility is unique. Send us your details, and a senior route logistics manager will reach out within 2 hours during normal business operations to schedule an on-site assessment.</p>

          <div style="margin-top: 3rem;">
            <h3 style="margin-bottom: 0.5rem;">Dispatch Headquarters</h3>
            <p>1900 San Diego Ave<br>San Diego, CA 92110</p>

            <h3 style="margin-bottom: 0.5rem;">Direct Contact</h3>
            <p style="font-size: 1.25rem; font-weight: 600; color: var(--brand-navy);">(619) 738-6819</p>
            <p>clean@bandgsouthwest.com</p>

            <h3 style="margin-bottom: 0.5rem; margin-top: 2rem;">Operating Hours</h3>
            <p>Dispatch Operations: Mon-Fri, 6AM - 6PM<br>Corporate Office: Mon-Fri, 6AM - 6PM</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="card" style="border-top: 4px solid var(--brand-amber);">
          <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Request an Assessment</h2>
          <form action="#" method="POST" onsubmit="event.preventDefault(); alert('Demo Form Submitted Successfully.');">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" class="form-control" required>
            </div>

            <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div class="form-group">
                <label for="email">Corporate Email</label>
                <input type="email" id="email" class="form-control" required>
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" class="form-control" required>
              </div>
            </div>

            <div class="form-group">
              <label for="company">Company / Facility Name</label>
              <input type="text" id="company" class="form-control">
            </div>

            <div class="form-group">
              <label for="service">Primary Service Needed</label>
              <select id="service" class="form-control">
                <option value="vct">VCT Floor Stripping & Waxing</option>
                <option value="carpet">Commercial Carpet Extraction</option>
                <option value="concrete">Concrete Polishing</option>
                <option value="other">Other / General Inquiry</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Facility Details (Est Sq Footage, Frequency)</label>
              <textarea id="message" class="form-control" rows="4"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Submit Request</button>
          </form>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>
